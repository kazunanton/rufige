# ================================================================
# Безопасность и базовая конфигурация (Apache)
# ================================================================

# Запретить листинг папок, если случайно нет index-файла
Options -Indexes

# Кодировка по умолчанию
AddDefaultCharset UTF-8

# ---- HTTPS (раскомментировать, когда включён SSL-сертификат) ----
# <IfModule mod_rewrite.c>
#     RewriteEngine On
#     RewriteCond %{HTTPS} !=on
#     RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]
# </IfModule>

# ---- Security-заголовки ----
<IfModule mod_headers.c>
    Header set X-Content-Type-Options "nosniff"
    Header set X-Frame-Options "SAMEORIGIN"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
    Header set Permissions-Policy "geolocation=(), microphone=(), camera=()"
    # Strict-Transport-Security включать только после того, как HTTPS точно работает:
    # Header always set Strict-Transport-Security "max-age=15552000; includeSubDomains"
</IfModule>

# ---- Запрет прямого доступа к чувствительным файлам ----
<FilesMatch "(^config\.php$|^config\.example\.php$|\.jsonl$|\.log$|\.md$|^README\.txt$)">
    <IfModule mod_authz_core.c>
        Require all denied
    </IfModule>
    <IfModule !mod_authz_core.c>
        Order allow,deny
        Deny from all
    </IfModule>
</FilesMatch>

# ---- Кэширование статики ----
<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/png   "access plus 7 days"
    ExpiresByType image/jpeg  "access plus 7 days"
    ExpiresByType image/svg+xml "access plus 7 days"
    ExpiresByType application/pdf "access plus 7 days"
    ExpiresByType text/css    "access plus 1 day"
    ExpiresByType text/html   "access plus 0 seconds"
</IfModule>
